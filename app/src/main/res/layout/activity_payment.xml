<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textColor="#06172E"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="Payment"
                android:textColor="#06172E"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Total Harga -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_grooming_card"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Harga"
                android:textColor="#7A869A"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Rp 0"
                android:textColor="#246BFE"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Metode Pembayaran -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="22dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_grooming_card"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metode Pembayaran"
                android:textColor="#06172E"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cardBri"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_grooming_input"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="🏦  BRI - 1234 5678 9000"
                android:textColor="#06172E"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cardGopay"
                android:clickable="true"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_grooming_input"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="📱  GoPay - 0812 3456 7890"
                android:textColor="#06172E"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Instruksi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="22dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_grooming_card"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instruksi Pembayaran"
                android:textColor="#06172E"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="1. Pilih salah satu metode pembayaran.\n2. Transfer sesuai total harga.\n3. Klik Confirm Payment setelah pembayaran dilakukan."
                android:textColor="#7A869A"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnConfirmPayment"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="26dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_confirm_booking"
            android:gravity="center"
            android:text="Confirm Payment"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>