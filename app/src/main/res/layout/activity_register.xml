<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="46dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp">

        <TextView
            android:id="@+id/backToLoginText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹  Back to Login"
            android:textColor="#203047"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp"
            android:text="🐾"
            android:textSize="38sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Create Account"
            android:textColor="#06172E"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="Join Satwalaya today!"
            android:textColor="#203047"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:background="@drawable/bg_auth_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Full Name -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Full Name" android:textColor="#06172E" android:textSize="13sp" android:textStyle="bold" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent" android:layout_height="46dp"
                android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input"
                android:hint="   John Doe" android:textSize="14sp" />

            <!-- Email -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="Email Address"
                android:textColor="#06172E" android:textSize="13sp" android:textStyle="bold" />

            <EditText
                android:id="@+id/etRegEmail"
                android:layout_width="match_parent" android:layout_height="46dp"
                android:layout_marginTop="8dp" android:background="@drawable/bg_auth_input"
                android:hint="   your@email.com" android:inputType="textEmailAddress" android:textSize="14sp" />

            <!-- Phone -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="Phone Number"
                android:textColor="#06172E" android:textSize="13sp" android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_auth_input"
                android:hint="   +62 812-3456-7890"
                android:inputType="phone"
                android:textSize="14sp" />

            <!-- Password -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="Password"
                android:textColor="#06172E" android:textSize="13sp" android:textStyle="bold" />

            <EditText
                android:id="@+id/etRegPassword"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_auth_input"
                android:hint="   ••••••••"
                android:inputType="textPassword"
                android:textSize="14sp" />

            <!-- Confirm Password -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="Confirm Password"
                android:textColor="#06172E" android:textSize="13sp" android:textStyle="bold" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_auth_input"
                android:hint="   ••••••••"
                android:inputType="textPassword"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/registerButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_auth_button"
                android:gravity="center"
                android:text="Register"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>